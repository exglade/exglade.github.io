---
import BlogFooter from "@/components/blog/BlogFooter.astro";
import PageNavigation from "@/components/site/PageNavigation";
import ThemeSwitcher from "@/components/site/ThemeSwitcher";
import { type HomeContent, homeContentByLocale } from "@/data/home";
import BaseLayout from "./BaseLayout.astro";

type Props = {
  title: string;
  description: string;
  navLabels?: HomeContent["nav"];
  socialImage?: string;
  noIndex?: boolean;
};

const {
  title,
  description,
  navLabels = homeContentByLocale.en.nav,
  socialImage,
  noIndex = false,
} = Astro.props;
---

<BaseLayout title={title} description={description} socialImage={socialImage} noIndex={noIndex}>
  <div
    class="pointer-events-none fixed inset-0 -z-10 bg-[radial-gradient(circle_at_top_right,var(--blog-background-glow),transparent_36rem)]"
    aria-hidden="true"
  ></div>

  <header class="py-8 md:py-12">
    <div class="flex flex-wrap items-center justify-between gap-x-6 gap-y-4">
      <nav aria-label="Primary">
        <PageNavigation
          activeItemKey="blog"
          navItems={[
            { key: "portfolio", label: navLabels.portfolio, href: "/", visible: true },
            { key: "blog", label: navLabels.blog, href: "/blog", visible: true },
          ]}
        />
      </nav>
      <ThemeSwitcher client:load />
    </div>
  </header>

  <main><slot /></main>
  <BlogFooter />
</BaseLayout>
