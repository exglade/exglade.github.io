---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  lang?: string;
  canonicalPath?: string;
  alternates?: {
    href: string;
    lang: string;
  }[];
}

const {
  title,
  description = "Kai Sheng — Software Engineer",
  lang = "en",
  canonicalPath,
  alternates = [],
} = Astro.props;

const canonicalURL = new URL(canonicalPath ?? Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={lang}>
  <head>
    <script is:inline>
    (() => {
      const storageKey = "theme";
      const root = document.documentElement;
      const storedPreference = window.localStorage.getItem(storageKey);
      const preference =
        storedPreference === "light" || storedPreference === "dark" || storedPreference === "system"
          ? storedPreference
          : "system";
      const resolvedTheme =
        preference === "system"
          ? window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light"
          : preference;

      root.dataset.theme = preference;
      root.classList.toggle("dark", resolvedTheme === "dark");
    })();
    </script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="color-scheme" content="light dark">
    <title>{title}</title>
    <meta name="description" content={description}>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL.href}>
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Kai Sheng RSS"
      href={new URL("/rss.xml", Astro.site).href}
    >
    {alternates.map((alternate) => (
      <link
        rel="alternate"
        hreflang={alternate.lang}
        href={new URL(alternate.href, Astro.site).href}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL("/", Astro.site).href}>

    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:url" content={canonicalURL.href}>
  </head>
  <body>
    <div class="mx-auto max-w-(--max-width) px-4 md:px-6"><slot /></div>
  </body>
</html>
