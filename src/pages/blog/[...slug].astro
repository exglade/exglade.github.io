---
import { render } from "astro:content";
import BackLink from "../../components/blog/BackLink.astro";
import BlogHeading from "../../components/blog/BlogHeading.astro";
import { Badge } from "../../components/ui/badge";
import { Separator } from "../../components/ui/separator";
import BlogLayout from "../../layouts/BlogLayout.astro";
import {
  getBlogPostTags,
  getBlogPostUrl,
  getBlogTagUrl,
  getPublishedBlogPosts,
} from "../../lib/blog";

export async function getStaticPaths() {
  const posts = await getPublishedBlogPosts();

  return posts.map((post) => ({
    params: { slug: getBlogPostUrl(post).replace("/blog/", "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const tags = getBlogPostTags(post);
---

<BlogLayout
  title={`${post.data.title} | Kai Sheng`}
  description={post.data.description || post.data.title}
  noIndex={post.data.draft === true}
>
  <article>
    <header class="max-w-2xl py-8 md:py-12">
      <BackLink href="/blog" label="Back to blog" />
      <BlogHeading>{post.data.title}</BlogHeading>
      <div class="mt-3 flex flex-wrap items-center gap-3 text-sm text-muted-foreground">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
        {tags.length > 0 && (
          <>
            <Separator orientation="vertical" />
            <ul class="flex list-none flex-wrap gap-2">
              {tags.map((tag) => (
                <li>
                  <a href={getBlogTagUrl(tag.slug)}>
                    <Badge variant="outline">{tag.label}</Badge>
                  </a>
                </li>
              ))}
            </ul>
          </>
        )}
      </div>
      {post.data.description && (
        <p class="mt-4 text-lg text-muted-foreground leading-relaxed">{post.data.description}</p>
      )}
    </header>

    <Separator />

    <div class="blog-prose pb-8"><Content /></div>
  </article>
</BlogLayout>
