---
import BackLink from "@/components/blog/BackLink.astro";
import BlogHeading from "@/components/blog/BlogHeading.astro";
import { Badge } from "@/components/ui/badge";
import BlogLayout from "@/layouts/BlogLayout.astro";
import { getBlogTagArchives, getBlogTagUrl, getPublishedBlogPosts } from "@/lib/blog";

const posts = await getPublishedBlogPosts();
const tagArchives = getBlogTagArchives(posts);
---

<BlogLayout title="Tags — Blog | Kai Sheng" description="Blog tags from Kai Sheng">
  <header class="max-w-2xl py-8 md:py-12">
    <BackLink href="/blog" label="Back to blog" />
    <BlogHeading>Tags</BlogHeading>
    <p class="mt-4 text-muted-foreground leading-relaxed">Browse posts by topic.</p>
  </header>

  <section aria-labelledby="blog-tags-heading">
    <h2 id="blog-tags-heading" class="sr-only">All tags</h2>
    {tagArchives.length > 0 ? (
      <ul class="flex list-none flex-wrap gap-3 py-8">
        {tagArchives.map((tag) => (
          <li>
            <a href={getBlogTagUrl(tag.slug)}>
              <Badge variant="outline">
                {tag.label} ({tag.posts.length})
              </Badge>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="py-8 text-muted-foreground">No tags yet.</p>
    )}
  </section>
</BlogLayout>
