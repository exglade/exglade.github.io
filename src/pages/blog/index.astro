---
import BlogHeading from "../../components/blog/BlogHeading.astro";
import BlogPostList from "../../components/blog/BlogPostList";
import { Separator } from "../../components/ui/separator";
import BlogLayout from "../../layouts/BlogLayout.astro";
import { getBlogPostYearGroups, getPublishedBlogPosts } from "../../lib/blog";

const posts = await getPublishedBlogPosts();
const groups = getBlogPostYearGroups(posts);
---

<BlogLayout title="Blog - Kai Sheng" description="Blog posts by Kai Sheng">
  <header class="max-w-2xl py-8 md:py-12">
    <BlogHeading>Blog</BlogHeading>
    <div class="mt-3 flex items-center gap-3 text-sm text-muted-foreground">
      <a class="underline-offset-4 hover:underline" href="/blog/tags">Tags</a>
      <Separator orientation="vertical" />
      <a class="underline-offset-4 hover:underline" href="/rss.xml">RSS</a>
    </div>
  </header>

  <section aria-labelledby="blog-archive-heading">
    <h2 id="blog-archive-heading" class="sr-only">Posts</h2>
    <BlogPostList groups={groups} />
  </section>
</BlogLayout>
