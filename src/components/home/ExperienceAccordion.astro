---
type Experience = {
  company: string;
  title: string;
  years: string;
  description: string;
  impact: string[];
};

type Props = {
  experiences: Experience[];
};

const { experiences } = Astro.props as Props;
---

<div data-slot="accordion" class="flex w-full flex-col">
  {experiences.map((experience) => (
      <details data-slot="accordion-item" class="group/accordion-item border-muted not-last:border-b">
        <summary
          data-slot="accordion-trigger"
          class="relative flex flex-1 list-none items-start justify-between rounded-lg border border-transparent bg-transparent p-4 text-left text-sm font-medium outline-none transition-all hover:underline focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50 [&::-webkit-details-marker]:hidden"
        >
          <span class="flex flex-1 flex-col gap-0">
            <span class="text-base font-semibold text-foreground">{experience.company}</span>
            <span class="text-sm text-muted-foreground">{experience.title}</span>
          </span>
          <span class="mr-10 text-right text-sm font-normal text-muted-foreground">
            {experience.years}
          </span>
          <svg
            data-slot="accordion-trigger-icon"
            class="pointer-events-none size-4 shrink-0 text-muted-foreground transition-transform group-open/accordion-item:rotate-180"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m6 9 6 6 6-6"></path>
          </svg>
        </summary>
        <div
          data-slot="accordion-content"
          class="overflow-hidden px-4 pb-2.5 text-sm [&_a]:underline [&_a]:underline-offset-3 [&_a]:hover:text-foreground [&_p:not(:last-child)]:mb-4"
        >
          <div class="flex max-w-2xl flex-col">
            <p class="text-muted-foreground">{experience.description}</p>
            <ul class="flex list-disc flex-col gap-2 pl-5 text-sm text-muted-foreground">
              {experience.impact.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>
      </details>
    ))}
</div>

<style>
[data-slot="accordion"] {
  interpolate-size: allow-keywords;
}

[data-slot="accordion-item"]::details-content {
  block-size: 0;
  overflow: hidden;
  transition:
    block-size 200ms ease-out,
    content-visibility 200ms ease-out allow-discrete;
}

[data-slot="accordion-item"][open]::details-content {
  block-size: auto;
}

@media (prefers-reduced-motion: reduce) {
  [data-slot="accordion-item"]::details-content {
    transition: none;
  }
}
</style>
