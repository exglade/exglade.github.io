---
import Badge from "@/components/ui/badge.astro";

type Skill = {
  label: string;
  href?: string;
};

type SkillGroup = {
  title: string;
  skills: Skill[];
};

type Props = {
  skillGroups: SkillGroup[];
};

const { skillGroups } = Astro.props;

const slugify = (value: string) =>
  value
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");
---

<div class="grid gap-10 p-4">
  {skillGroups.map((group, index) => {
    const headingId = `skills-group-${slugify(group.title) || index}`;

    return (
      <section aria-labelledby={headingId} class="flex flex-col gap-2">
        <h3
          id={headingId}
          class="text-sm font-semibold uppercase tracking-[0.2em] text-muted-foreground"
        >
          {group.title}
        </h3>
        <ul class="flex flex-wrap gap-2">
          {group.skills.map((skill) =>
            <li>
              {skill.href ? (
                <Badge
                  as="a"
                  href={skill.href}
                  target="_blank"
                  aria-label={`${skill.label} official website`}
                  class="no-underline hover:no-underline focus:no-underline"
                >
                  {skill.label}
                </Badge>
              ) : (
                <Badge>{skill.label}</Badge>
              )}
            </li>,
          )}
        </ul>
      </section>
    );
  })}
</div>
