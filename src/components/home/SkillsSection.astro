---
import { badgeVariants } from "@/components/ui/badge";

type Skill = {
  label: string;
  href?: string;
};

type SkillGroup = {
  title: string;
  skills: Skill[];
};

type Props = {
  skillGroups: SkillGroup[];
};

const { skillGroups } = Astro.props;

const slugify = (value: string) =>
  value
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");
---

<div class="grid gap-10 p-4">
  {skillGroups.map((group, index) => {
    const headingId = `skills-group-${slugify(group.title) || index}`;

    return (
      <section aria-labelledby={headingId} class="flex flex-col gap-2">
        <h3
          id={headingId}
          class="text-sm font-semibold uppercase tracking-[0.2em] text-muted-foreground"
        >
          {group.title}
        </h3>
        <div class="flex flex-wrap gap-2">
          {group.skills.map((skill) =>
            skill.href ? (
              <a
                href={skill.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${skill.label} official website`}
                class:list={[
                  badgeVariants(),
                  "no-underline hover:no-underline focus:no-underline",
                ]}
              >
                {skill.label}
              </a>
            ) : (
              <span class={badgeVariants()}>{skill.label}</span>
            ),
          )}
        </div>
      </section>
    );
  })}
</div>
