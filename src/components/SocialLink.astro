---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"a"> & {
  href: string;
};

const { href, class: className, target = "_blank", rel, ...rest } = Astro.props as Props;

const resolvedRel = rel ?? (target === "_blank" ? "noopener noreferrer" : undefined);
---

<!-- biome-ignore lint/a11y/useAnchorContent: Accessible link content is supplied through the Astro slot. -->
<a
  href={href}
  target={target}
  rel={resolvedRel}
  class:list={[
    "inline-flex items-center gap-1 rounded-lg border border-transparent text-base font-medium text-foreground no-underline hover:no-underline focus-visible:border-ring focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-ring/50 [&_.social-link__label]:relative [&_.social-link__label]:inline-block [&_.social-link__label]:after:absolute [&_.social-link__label]:after:left-0 [&_.social-link__label]:after:-bottom-[0.08em] [&_.social-link__label]:after:h-px [&_.social-link__label]:after:w-full [&_.social-link__label]:after:origin-left [&_.social-link__label]:after:scale-x-0 [&_.social-link__label]:after:bg-current [&_.social-link__label]:after:transition-transform [&_.social-link__label]:after:duration-[220ms] [&_.social-link__label]:after:content-[''] hover:[&_.social-link__label]:after:scale-x-100",
    className,
  ]}
  {...rest}
>
  <slot />
</a>
